// ─── Blog ────────────────────────────────────────────────────────────────────

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id          String         @id @default(cuid())
  slug        String         @unique @db.VarChar(191)
  title       String
  excerpt     String?        @db.Text
  body        String         @db.Text
  category    String         @db.VarChar(100)
  status      BlogPostStatus @default(PUBLISHED)
  authorId    String? @map("authorid")
  author      User?          @relation("UserBlogPosts", fields: [authorId], references: [id])
  publishedAt DateTime? @map("publishedat")
  createdAt   DateTime       @default(now()) @map("createdat")
  updatedAt   DateTime       @updatedAt @map("updatedat")

  @@map("blog_posts")
}

// ─── Pricing plans (marketing — not billing subscriptions) ───────────────────

model PricingPlan {
  id        String   @id @default(cuid())
  slug      String   @unique @db.VarChar(191)
  name      String
  price     Decimal  @db.Decimal(10, 2) @default(0)
  period    String?  @db.VarChar(50)
  features  Json
  isPopular Boolean  @default(false) @map("ispopular")
  sortOrder Int      @default(0) @map("sortorder")
  isActive  Boolean  @default(true) @map("isactive")
  ctaLabel  String   @default("Get started") @db.VarChar(100) @map("ctalabel")
  ctaHref   String?  @db.VarChar(500) @map("ctahref")
  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")

  @@map("pricing_plans")
}

// ─── Mentors ─────────────────────────────────────────────────────────────────

enum MentorStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MentorType {
  ACADEMIC      // Universities, colleges, researchers
  INDUSTRY      // Companies, startups, professionals
  INNOVATION    // Founders, investors, ecosystem leaders
  GENERAL
}

enum MentorRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CLOSED
}

enum MentorSessionStatus {
  REQUESTED
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MentorSessionType {
  INTRO_CALL
  GUIDANCE
  OFFICE_HOURS
  GROUP_SESSION
}

enum GroupSessionMode {
  VIRTUAL
  PHYSICAL
  HYBRID
}

model MentorProfile {
  id                    String              @id @default(cuid())
  slug                  String              @unique @db.VarChar(191)
  userId                String?             @unique @map("userid")
  user                  User?               @relation("UserMentorProfile", fields: [userId], references: [id], onDelete: SetNull)
  mentorType            MentorType          @default(GENERAL)
  displayName           String @map("displayname")
  title                 String?             @db.VarChar(255)
  company               String?             @db.VarChar(255)
  companyLogoUrl        String? @map("companylogourl")
  avatarUrl             String? @map("avatarurl")
  bio                   String?             @db.Text
  hook                  String?             @db.VarChar(280)
  quote                 String?             @db.VarChar(500)
  videoIntroUrl         String? @map("videointrourl")
  city                  String?             @db.VarChar(100)
  country               String?             @db.VarChar(100)
  expertiseTags         Json                @default("[]") @map("expertisetags")
  tracks                Json                @default("[]")
  languages             Json                @default("[]")
  yearsExperience       Int                 @default(0) @map("yearsexperience")
  linkedin              String?
  github                String?
  learningPath          Json                @default("[]") @map("learningpath")
  recommendedCourseIds  Json                @default("[]") @map("recommendedcourseids")
  recommendedKitSlugs   Json                @default("[]") @map("recommendedkitslugs")
  officeHoursNote       String?             @db.Text @map("officehoursnote")
  bookingUrl            String? @map("bookingurl")
  isFeatured            Boolean             @default(false) @map("isfeatured")
  isAcceptingRequests   Boolean             @default(true) @map("isacceptingrequests")
  agreedToCodeOfConduct Boolean             @default(false) @map("agreedtocodeofconduct")
  studentsHelped        Int                 @default(0) @map("studentshelped")
  averageRating         Float? @map("averagerating")
  ratingCount           Int                 @default(0) @map("ratingcount")
  sortOrder             Int                 @default(0) @map("sortorder")
  status                MentorStatus        @default(DRAFT)
  requests              MentorRequest[]
  sessions              MentorSession[]
  officeHours           MentorOfficeHour[]
  groupSessions         MentorGroupSession[]
  cohorts               MentorCohort[]
  createdAt             DateTime            @default(now()) @map("createdat")
  updatedAt             DateTime            @updatedAt @map("updatedat")

  @@map("mentor_profiles")
}

model MentorRequest {
  id          String              @id @default(cuid())
  learnerId   String @map("learnerid")
  learner     User                @relation("LearnerMentorRequests", fields: [learnerId], references: [id], onDelete: Cascade)
  mentorId    String @map("mentorid")
  mentor      MentorProfile       @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  goal        String              @db.VarChar(500)
  message     String              @db.Text
  status      MentorRequestStatus @default(PENDING)
  mentorReply String?             @db.Text @map("mentorreply")
  sessions    MentorSession[]
  createdAt   DateTime            @default(now()) @map("createdat")
  updatedAt   DateTime            @updatedAt @map("updatedat")

  @@index([learnerId])
  @@index([mentorId])
  @@map("mentor_requests")
}

model MentorSession {
  id              String              @id @default(cuid())
  mentorId        String @map("mentorid")
  mentor          MentorProfile       @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  learnerId       String @map("learnerid")
  learner         User                @relation("LearnerMentorSessions", fields: [learnerId], references: [id], onDelete: Cascade)
  requestId       String? @map("requestid")
  request         MentorRequest?      @relation(fields: [requestId], references: [id], onDelete: SetNull)
  type            MentorSessionType   @default(GUIDANCE)
  status          MentorSessionStatus @default(REQUESTED)
  topic           String?             @db.VarChar(500)
  notes           String?             @db.Text
  scheduledAt     DateTime? @map("scheduledat")
  durationMins    Int                 @default(30) @map("durationmins")
  meetingUrl      String? @map("meetingurl")
  smsReminderSent Boolean             @default(false) @map("smsremindersent")
  // Learner feedback after session
  rating          Int?                // 1–5
  learnerFeedback String?             @db.VarChar(1000) @map("learnerfeedback")
  ratedAt         DateTime? @map("ratedat")
  createdAt       DateTime            @default(now()) @map("createdat")
  updatedAt       DateTime            @updatedAt @map("updatedat")

  @@index([mentorId])
  @@index([learnerId])
  @@index([scheduledAt])
  @@map("mentor_sessions")
}

model MentorOfficeHour {
  id          String        @id @default(cuid())
  mentorId    String @map("mentorid")
  mentor      MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  title       String        @db.VarChar(255)
  description String?       @db.Text
  dayOfWeek   Int @map("dayofweek")
  startTime   String        @db.VarChar(10) @map("starttime")
  endTime     String        @db.VarChar(10) @map("endtime")
  timezone    String        @default("Africa/Dar_es_Salaam") @db.VarChar(50)
  meetingUrl  String? @map("meetingurl")
  isActive    Boolean       @default(true) @map("isactive")
  createdAt   DateTime      @default(now()) @map("createdat")
  updatedAt   DateTime      @updatedAt @map("updatedat")

  @@index([mentorId])
  @@map("mentor_office_hours")
}

model MentorGroupSession {
  id           String                       @id @default(cuid())
  mentorId     String @map("mentorid")
  mentor       MentorProfile                @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  cohortId     String? @map("cohortid")
  cohort       MentorCohort?                @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  title        String
  description  String?                      @db.Text
  sessionMode  GroupSessionMode             @default(VIRTUAL)
  venue        String?                      @db.VarChar(500)
  scheduledAt  DateTime @map("scheduledat")
  durationMins Int                          @default(60) @map("durationmins")
  maxAttendees Int                          @default(20) @map("maxattendees")
  meetingUrl   String? @map("meetingurl")
  recordingUrl String? @map("recordingurl")
  channelSlug  String                       @default("mentorship") @db.VarChar(50) @map("channelslug")
  isActive     Boolean                      @default(true) @map("isactive")
  attendees    MentorGroupSessionAttendee[]
  createdAt    DateTime                     @default(now()) @map("createdat")
  updatedAt    DateTime                     @updatedAt @map("updatedat")

  @@index([mentorId])
  @@index([cohortId])
  @@index([scheduledAt])
  @@map("mentor_group_sessions")
}

model MentorGroupSessionAttendee {
  id        String             @id @default(cuid())
  sessionId String @map("sessionid")
  session   MentorGroupSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String @map("userid")
  user      User               @relation("UserGroupSessionAttendees", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime           @default(now()) @map("joinedat")

  @@unique([sessionId, userId])
  @@map("mentor_group_session_attendees")
}

// ─── Mentorship Cohorts ───────────────────────────────────────────────────────

model MentorCohort {
  id          String               @id @default(cuid())
  mentorId    String @map("mentorid")
  mentor      MentorProfile        @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  title       String               @db.VarChar(255)
  description String?              @db.Text
  track       String               @db.VarChar(100)
  startsAt    DateTime @map("startsat")
  endsAt      DateTime? @map("endsat")
  maxMembers  Int                  @default(20) @map("maxmembers")
  isActive    Boolean              @default(true) @map("isactive")
  members     MentorCohortMember[]
  sessions    MentorGroupSession[]
  createdAt   DateTime             @default(now()) @map("createdat")
  updatedAt   DateTime             @updatedAt @map("updatedat")

  @@index([mentorId])
  @@map("mentor_cohorts")
}

model MentorCohortMember {
  id        String       @id @default(cuid())
  cohortId  String @map("cohortid")
  cohort    MentorCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId    String @map("userid")
  user      User         @relation("UserCohortMemberships", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime     @default(now()) @map("joinedat")

  @@unique([cohortId, userId])
  @@index([userId])
  @@map("mentor_cohort_members")
}

// ─── Innovation Showcase ──────────────────────────────────────────────────────

enum ShowcaseStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

model ShowcaseProject {
  id           String          @id @default(cuid())
  userId       String @map("userid")
  user         User            @relation("UserShowcaseProjects", fields: [userId], references: [id], onDelete: Cascade)
  title        String          @db.VarChar(255)
  tagline      String?         @db.VarChar(280)
  description  String          @db.Text
  thumbnailUrl String? @map("thumbnailurl")
  demoUrl      String? @map("demourl")
  repoUrl      String? @map("repourl")
  videoUrl     String? @map("videourl")
  techStack    Json            @default("[]") @map("techstack")
  track        String?         @db.VarChar(100)
  status       ShowcaseStatus  @default(DRAFT)
  isFeatured   Boolean         @default(false) @map("isfeatured")
  viewCount    Int             @default(0) @map("viewcount")
  likeCount    Int             @default(0) @map("likecount")
  likes        ShowcaseLike[]
  createdAt    DateTime        @default(now()) @map("createdat")
  updatedAt    DateTime        @updatedAt @map("updatedat")

  @@index([userId])
  @@index([status])
  @@map("showcase_projects")
}

model ShowcaseLike {
  id        String          @id @default(cuid())
  projectId String @map("projectid")
  project   ShowcaseProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String @map("userid")
  user      User            @relation("UserShowcaseLikes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("createdat")

  @@unique([projectId, userId])
  @@index([userId])
  @@map("showcase_likes")
}
