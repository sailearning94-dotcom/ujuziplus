// ─── Programs & competitions ────────────────────────────────────────────────

enum ProgramFormat {
  ONLINE
  IN_PERSON
  HYBRID
}

enum ProgramStatus {
  DRAFT
  OPEN
  FULL
  CLOSED
  ARCHIVED
}

model Program {
  id             String               @id @default(cuid())
  slug           String               @unique @db.VarChar(191)
  title          String
  type           String               @db.VarChar(50)
  thumbnailUrl   String? @map("thumbnailurl")
  posterUrl      String? @map("posterurl")
  description    String?              @db.Text
  startDate      DateTime? @map("startdate")
  endDate        DateTime? @map("enddate")
  format         ProgramFormat        @default(HYBRID)
  seats          Int                  @default(50)
  enrolledCount  Int                  @default(0) @map("enrolledcount")
  price          Decimal              @db.Decimal(10, 2) @default(0)
  status         ProgramStatus        @default(OPEN)
  organizationId String? @map("organizationid")
  organization   Organization?        @relation("OrgPrograms", fields: [organizationId], references: [id])
  registrations  ProgramRegistration[]
  orderItems     OrderItem[]
  createdAt      DateTime             @default(now()) @map("createdat")
  updatedAt      DateTime             @updatedAt @map("updatedat")

  @@map("programs")
}

model ProgramRegistration {
  id           String   @id @default(cuid())
  userId       String @map("userid")
  user         User     @relation("UserProgramRegs", fields: [userId], references: [id], onDelete: Cascade)
  programId    String @map("programid")
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  orderId      String? @map("orderid")
  registeredAt DateTime @default(now()) @map("registeredat")

  @@unique([userId, programId])
  @@map("program_registrations")
}

enum CompetitionStatus {
  UPCOMING
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
}

model Competition {
  id            String                  @id @default(cuid())
  slug          String                  @unique @db.VarChar(191)
  title         String
  thumbnailUrl  String? @map("thumbnailurl")
  description   String?                 @db.Text
  startDate     DateTime? @map("startdate")
  endDate       DateTime? @map("enddate")
  prize         String?                 @db.VarChar(255)
  teamsCount    Int                     @default(0) @map("teamscount")
  status        CompetitionStatus       @default(UPCOMING)
  registrations CompetitionRegistration[]
  createdAt     DateTime                @default(now()) @map("createdat")
  updatedAt     DateTime                @updatedAt @map("updatedat")

  @@map("competitions")
}

model CompetitionRegistration {
  id           String      @id @default(cuid())
  userId       String @map("userid")
  user         User        @relation("UserCompetitionRegs", fields: [userId], references: [id], onDelete: Cascade)
  competitionId String @map("competitionid")
  competition  Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  teamName     String?     @db.VarChar(100) @map("teamname")
  registeredAt DateTime    @default(now()) @map("registeredat")

  @@unique([userId, competitionId])
  @@map("competition_registrations")
}

// ─── Organizations & org kit logistics ───────────────────────────────────────

enum OrgType {
  UNIVERSITY
  HUB
  SCHOOL
  OTHER
}

enum OrgMemberRole {
  ADMIN
  INSTRUCTOR
  MEMBER
}

enum OrgKitRequestStatus {
  PENDING
  APPROVED
  FULFILLED
  REJECTED
}

model Organization {
  id           String               @id @default(cuid())
  slug         String               @unique @db.VarChar(191)
  name         String
  type         OrgType              @default(UNIVERSITY)
  logoUrl      String? @map("logourl")
  memberCount  Int                  @default(0) @map("membercount")
  isVerified   Boolean              @default(false) @map("isverified")
  members      OrganizationMember[]
  invites      OrgInvite[]
  kitInventory OrgKitInventory[]
  kitRequests  OrgKitRequest[]
  programs     Program[]            @relation("OrgPrograms")
  solutions    Solution[]           @relation("OrgSolutions")
  createdAt    DateTime             @default(now()) @map("createdat")
  updatedAt    DateTime             @updatedAt @map("updatedat")

  @@map("organizations")
}

enum OrgInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model OrgInvite {
  id          String          @id @default(cuid())
  orgId       String @map("orgid")
  org         Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email       String          @db.VarChar(191)
  role        OrgMemberRole   @default(MEMBER)
  token       String          @unique @db.VarChar(191)
  status      OrgInviteStatus @default(PENDING)
  invitedById String @map("invitedbyid")
  invitedBy   User            @relation("OrgInvitesSent", fields: [invitedById], references: [id])
  expiresAt   DateTime @map("expiresat")
  acceptedAt  DateTime? @map("acceptedat")
  createdAt   DateTime        @default(now()) @map("createdat")

  @@index([orgId, status])
  @@map("org_invites")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String @map("userid")
  user      User     @relation("UserPushSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @db.VarChar(500)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  userAgent String?  @db.VarChar(500) @map("useragent")
  createdAt DateTime @default(now()) @map("createdat")

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

model OrganizationMember {
  id     String        @id @default(cuid())
  orgId  String @map("orgid")
  org    Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String @map("userid")
  user   User          @relation("UserOrgMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role   OrgMemberRole @default(MEMBER)

  @@unique([orgId, userId])
  @@map("organization_members")
}

model OrgKitInventory {
  id                String       @id @default(cuid())
  orgId             String @map("orgid")
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  kitId             String @map("kitid")
  kit               Kit          @relation(fields: [kitId], references: [id], onDelete: Cascade)
  quantityOnHand    Int          @default(0) @map("quantityonhand")
  quantityAllocated Int          @default(0) @map("quantityallocated")
  reorderLevel      Int          @default(5) @map("reorderlevel")

  @@unique([orgId, kitId])
  @@map("org_kit_inventory")
}

model OrgKitRequest {
  id          String              @id @default(cuid())
  orgId       String @map("orgid")
  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  kitId       String @map("kitid")
  kit         Kit                 @relation(fields: [kitId], references: [id], onDelete: Cascade)
  requesterId String @map("requesterid")
  requester   User                @relation("UserOrgKitRequests", fields: [requesterId], references: [id])
  quantity    Int                 @default(1)
  status      OrgKitRequestStatus @default(PENDING)
  notes       String?             @db.Text
  createdAt   DateTime            @default(now()) @map("createdat")
  updatedAt   DateTime            @updatedAt @map("updatedat")

  @@map("org_kit_requests")
}

// ─── Projects showcase ────────────────────────────────────────────────────────

enum ProjectStatus {
  IDEA
  PROTOTYPE
  MVP
  LAUNCHED
}

model Project {
  id           String        @id @default(cuid())
  slug         String        @unique @db.VarChar(191)
  title        String
  description  String        @db.Text
  thumbnailUrl String? @map("thumbnailurl")
  category     String        @db.VarChar(100)
  tags         Json?
  status       ProjectStatus @default(PROTOTYPE)
  githubUrl    String?       @db.VarChar(500) @map("githuburl")
  demoUrl      String?       @db.VarChar(500) @map("demourl")
  creatorId    String @map("creatorid")
  creator      User          @relation("UserProjects", fields: [creatorId], references: [id])
  likesCount   Int           @default(0) @map("likescount")
  isPublished  Boolean       @default(true) @map("ispublished")
  likes        ProjectLike[]
  createdAt    DateTime      @default(now()) @map("createdat")
  updatedAt    DateTime      @updatedAt @map("updatedat")

  @@index([creatorId])
  @@map("projects")
}

model ProjectLike {
  id        String   @id @default(cuid())
  userId    String @map("userid")
  user      User     @relation("UserProjectLikes", fields: [userId], references: [id], onDelete: Cascade)
  projectId String @map("projectid")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("createdat")

  @@unique([userId, projectId])
  @@map("project_likes")
}

// ─── IoT Solutions workspace ─────────────────────────────────────────────────

enum ContentDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SolutionStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

model Solution {
  id              String            @id @default(cuid())
  slug            String            @unique @db.VarChar(191)
  title           String
  subtitle        String?
  description     String            @db.Text
  level           ContentDifficulty @default(BEGINNER)
  hours           Int               @default(1)
  thumbnailUrl    String? @map("thumbnailurl")
  tags            Json?
  components      Json?
  relatedKitSlugs Json? @map("relatedkitslugs")
  labSteps        Json? @map("labsteps")
  codeTemplate    String?           @db.Text @map("codetemplate")
  status          SolutionStatus    @default(DRAFT)
  // Community authorship
  authorId        String? @map("authorid")
  author          User?             @relation("AuthoredSolutions", fields: [authorId], references: [id], onDelete: SetNull)
  orgId           String? @map("orgid")
  organization    Organization?     @relation("OrgSolutions", fields: [orgId], references: [id], onDelete: SetNull)
  rejectionReason String? @map("rejectionreason")
  viewCount       Int               @default(0) @map("viewcount")
  joins           SolutionJoin[]
  createdAt       DateTime          @default(now()) @map("createdat")
  updatedAt       DateTime          @updatedAt @map("updatedat")

  @@map("solutions")
}

model SolutionJoin {
  id          String   @id @default(cuid())
  userId      String @map("userid")
  user        User     @relation("UserSolutionJoins", fields: [userId], references: [id], onDelete: Cascade)
  solutionId  String @map("solutionid")
  solution    Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  labProgress Json? @map("labprogress")
  joinedAt    DateTime @default(now()) @map("joinedat")

  @@unique([userId, solutionId])
  @@map("solution_joins")
}

