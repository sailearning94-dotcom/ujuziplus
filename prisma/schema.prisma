  @@map("lab_resources")
}

model UserLabResource {
  id            String      @id @default(cuid())
  userId        String @map("userid")
  user          User        @relation("UserLabResources", fields: [userId], references: [id], onDelete: Cascade)
  labResourceId String @map("labresourceid")
  labResource   LabResource @relation(fields: [labResourceId], references: [id], onDelete: Cascade)
