  slug         String            @unique @db.VarChar(191)
  title        String
  description  String?           @db.Text
  content      String?           @db.Text
  type         LabResourceType   @default(COMPONENT)
  category     String?           @db.VarChar(100)
  fileUrl      String?           @db.VarChar(500) @map("fileurl")
  pdfUrls      Json? @map("pdfurls")
  imageUrls    Json? @map("imageurls")
  externalUrl  String?           @db.VarChar(500) @map("externalurl")
  thumbnailUrl String? @map("thumbnailurl")
  bookmarks    UserLabResource[]
  createdAt    DateTime          @default(now()) @map("createdat")
