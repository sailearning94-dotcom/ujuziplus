// UjuziLab — Prisma schema
// Phase 0: Identity & Auth
// Run:  npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Roles ───────────────────────────────────────────────────────────────────
enum Role {
  STUDENT
  INSTRUCTOR
  ORG_ADMIN
  MODERATOR
  ADMIN
}

// ─── Users ───────────────────────────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  fullName      String @map("fullname")
  email         String   @unique @db.VarChar(191)
  username      String   @unique @db.VarChar(100)
  passwordHash  String @map("passwordhash")
  role          Role     @default(STUDENT)

  // Profile fields
  avatarUrl     String? @map("avatarurl")
  bio           String?  @db.Text
  location      String?
  website       String?
  linkedin      String?
  github        String?

  // Privacy (public profile visibility)
  publicProfile              Boolean @default(true) @map("publicprofile")
  showCoursesOnProfile       Boolean @default(true) @map("showcoursesonprofile")
  showCertificatesOnProfile  Boolean @default(true) @map("showcertificatesonprofile")

  // Account state
  isActive      Boolean  @default(true) @map("isactive")
  emailVerified Boolean  @default(false) @map("emailverified")

  createdAt     DateTime @default(now()) @map("createdat")
  updatedAt     DateTime @updatedAt @map("updatedat")

  // Relations
  resetTokens    PasswordResetToken[]
  courses        Course[]             @relation("InstructorCourses")
  enrollments    Enrollment[]
  orders         Order[]              @relation("UserOrders")
  quizAttempts   QuizAttempt[]        @relation("UserQuizAttempts")
  certificates   Certificate[]        @relation("UserCertificates")
  discussions    Discussion[]         @relation("UserDiscussions")
  replies        DiscussionReply[]    @relation("UserReplies")
  likes          DiscussionLike[]     @relation("UserLikes")
  notifications  Notification[]       @relation("UserNotifications")
  wishlist       WishlistItem[]       @relation("UserWishlist")
  assignmentSubmissions AssignmentSubmission[] @relation("StudentSubmissions")
  gradedSubmissions     AssignmentSubmission[] @relation("GradedSubmissions")
  payoutProfile  InstructorPayoutProfile? @relation("InstructorPayoutProfile")
  payouts        InstructorPayout[]   @relation("InstructorPayouts")
  programRegs    ProgramRegistration[] @relation("UserProgramRegs")
  competitionRegs CompetitionRegistration[] @relation("UserCompetitionRegs")
  kitPurchases   KitPurchase[]        @relation("UserKitPurchases")
  orgMemberships OrganizationMember[] @relation("UserOrgMemberships")
  orgKitRequests OrgKitRequest[]      @relation("UserOrgKitRequests")
  notificationPreferences NotificationPreference[] @relation("UserNotificationPrefs")
  pushSubscriptions     PushSubscription[]       @relation("UserPushSubscriptions")
  fcmTokens             FcmDeviceToken[]         @relation("UserFcmTokens")
  orgInvitesSent        OrgInvite[]              @relation("OrgInvitesSent")
  projects              Project[]                @relation("UserProjects")
  projectLikes          ProjectLike[]            @relation("UserProjectLikes")
  solutionJoins         SolutionJoin[]           @relation("UserSolutionJoins")
  authoredSolutions     Solution[]               @relation("AuthoredSolutions")
  labResourceBookmarks  UserLabResource[]        @relation("UserLabResources")
  blogPosts             BlogPost[]               @relation("UserBlogPosts")
  followers             UserFollow[]             @relation("UserFollowers")
  following             UserFollow[]             @relation("UserFollowing")
  mentorProfile         MentorProfile?              @relation("UserMentorProfile")
  mentorRequests        MentorRequest[]             @relation("LearnerMentorRequests")
  mentorSessions        MentorSession[]             @relation("LearnerMentorSessions")
  groupSessionAttendees MentorGroupSessionAttendee[] @relation("UserGroupSessionAttendees")
  cohortMemberships     MentorCohortMember[]        @relation("UserCohortMemberships")
  showcaseProjects      ShowcaseProject[]           @relation("UserShowcaseProjects")
  showcaseLikes         ShowcaseLike[]              @relation("UserShowcaseLikes")

  @@map("users")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String @map("followerid")
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String @map("followingid")
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("createdat")

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

model FcmDeviceToken {
  id        String   @id @default(cuid())
  userId    String @map("userid")
  user      User     @relation("UserFcmTokens", fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(500)
  platform  String   @default("web") @db.VarChar(20)
  label     String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("createdat")
  updatedAt DateTime @updatedAt @map("updatedat")

  @@index([userId])
  @@map("fcm_device_tokens")
}

// ─── Course enums ─────────────────────────────────────────────────────────────
enum CourseStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonType {
  VIDEO
  ARTICLE
  AUDIO
  QUIZ
  ASSIGNMENT
}

// ─── Courses ──────────────────────────────────────────────────────────────────
model Course {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique @db.VarChar(191)
  subtitle      String?
  description   String?      @db.Text
  thumbnailUrl  String? @map("thumbnailurl")
  instructorId  String @map("instructorid")
  instructor    User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  category      String?
  level         CourseLevel  @default(BEGINNER)
  language      String       @default("English")
  price         Decimal?     @db.Decimal(10, 2)
  discountPrice Decimal?     @db.Decimal(10, 2) @map("discountprice")
  isFree        Boolean      @default(false) @map("isfree")
  durationHours Float        @default(0) @map("durationhours")
  status        CourseStatus @default(DRAFT)

  // Requirements
  whatYouLearn   Json?       @map("whatyoulearn") // String[]
  prerequisites  String?     @db.Text
  targetAudience String?     @map("targetaudience")
  linkedKitSlugs Json?       @map("linkedkitslugs") // String[]

  // SEO & certificate
  metaTitle     String? @map("metatitle")
  metaDesc      String? @map("metadesc")
  enableCert    Boolean      @default(true) @map("enablecert")

  // Moderation
  reviewNote    String?      @db.Text @map("reviewnote")

  modules       CourseModule[]
  enrollments   Enrollment[]  @relation("Enrollments")
  orderItems    OrderItem[]   @relation("OrderItems")
  certificates  Certificate[]        @relation("CourseCertificates")
  certTemplate  CertificateTemplate? @relation("CourseCertTemplate")
  discussions   Discussion[]         @relation("CourseDiscussions")
  wishlistItems WishlistItem[]       @relation("CourseWishlist")

  createdAt     DateTime     @default(now()) @map("createdat")
  updatedAt     DateTime     @updatedAt @map("updatedat")

  @@map("courses")
}

model CourseModule {
  id         String    @id @default(cuid())
  courseId   String @map("courseid")
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title      String
  orderIndex Int       @default(0) @map("orderindex")
  lessons    Lesson[]
  createdAt  DateTime  @default(now()) @map("createdat")

  @@map("course_modules")
}

model Lesson {
  id              String       @id @default(cuid())
  moduleId        String @map("moduleid")
  module          CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title           String
  slug            String       @db.VarChar(191)
  type            LessonType   @default(ARTICLE)
  videoUrl        String? @map("videourl")
  articleBody     String?      @db.Text @map("articlebody")
  audioUrl        String? @map("audiourl")
  attachments     Json?        // [{ name, url, size }]
  durationSeconds Int? @map("durationseconds")
  isFreePreview   Boolean      @default(false) @map("isfreepreview")
  orderIndex      Int          @default(0) @map("orderindex")
  createdAt       DateTime     @default(now()) @map("createdat")
  updatedAt       DateTime     @updatedAt @map("updatedat")

  progress        LessonProgress[]
  quiz            Quiz?
  assignment      Assignment?

  @@map("lessons")
}

// ─── Quizzes ──────────────────────────────────────────────────────────────────

model Quiz {
  id        String         @id @default(cuid())
  lessonId  String         @unique @map("lessonid")
  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  passMark  Int            @default(70) @map("passmark")
  timeLimit Int? @map("timelimit")
  questions QuizQuestion[]
  attempts  QuizAttempt[]
  createdAt DateTime       @default(now()) @map("createdat")
  updatedAt DateTime       @updatedAt @map("updatedat")

  @@map("quizzes")
}

model QuizQuestion {
  id          String              @id @default(cuid())
  quizId      String @map("quizid")
  quiz        Quiz                @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text        String              @db.Text
  explanation String?             @db.Text
  orderIndex  Int                 @default(0) @map("orderindex")
  options     QuizOption[]
  answers     QuizAttemptAnswer[]
  createdAt   DateTime            @default(now()) @map("createdat")

  @@map("quiz_questions")
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String @map("questionid")
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean      @default(false) @map("iscorrect")
  orderIndex Int          @default(0) @map("orderindex")

  @@map("quiz_options")
}

model QuizAttempt {
  id          String              @id @default(cuid())
  quizId      String @map("quizid")
  quiz        Quiz                @relation(fields: [quizId], references: [id])
  userId      String @map("userid")
  user        User                @relation("UserQuizAttempts", fields: [userId], references: [id])
  score       Int
  passed      Boolean
  startedAt   DateTime            @default(now()) @map("startedat")
  completedAt DateTime? @map("completedat")
  answers     QuizAttemptAnswer[]

  @@map("quiz_attempts")
}

model QuizAttemptAnswer {
  id         String       @id @default(cuid())
  attemptId  String @map("attemptid")
  attempt    QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String @map("questionid")
  question   QuizQuestion @relation(fields: [questionId], references: [id])
  optionId   String? @map("optionid")
  isCorrect  Boolean @map("iscorrect")

  @@map("quiz_attempt_answers")
}

// ─── Enrollment & progress ────────────────────────────────────────────────────

model Enrollment {
  id          String    @id @default(cuid())
  userId      String @map("userid")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String @map("courseid")
  course      Course    @relation("Enrollments", fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt  DateTime  @default(now()) @map("enrolledat")
  completedAt DateTime? @map("completedat")

  progress              LessonProgress[]
  assignmentSubmissions AssignmentSubmission[]

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id           String     @id @default(cuid())
  enrollmentId String @map("enrollmentid")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String @map("lessonid")
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt  DateTime   @default(now()) @map("completedat")

  @@unique([enrollmentId, lessonId])
  @@map("lesson_progress")
}

// ─── Certificates ─────────────────────────────────────────────────────────────

model Certificate {
  id         String   @id @default(cuid())
  userId     String @map("userid")
  user       User     @relation("UserCertificates", fields: [userId], references: [id])
  courseId   String @map("courseid")
  course     Course   @relation("CourseCertificates", fields: [courseId], references: [id])
  issuedAt   DateTime @default(now()) @map("issuedat")
  verifyCode String   @unique @default(cuid()) @map("verifycode")

  @@unique([userId, courseId])
  @@map("certificates")
}

// PDF template uploaded by instructor/admin. Fields filled: student_name,
// course_title, instructor_name, issue_date, verify_code, duration_hours
model CertificateTemplate {
  id          String   @id @default(cuid())
  courseId    String   @unique @map("courseid")
  course      Course   @relation("CourseCertTemplate", fields: [courseId], references: [id], onDelete: Cascade)
  filePath    String @map("filepath")
  uploadedAt  DateTime @default(now()) @map("uploadedat")
  updatedAt   DateTime @updatedAt @map("updatedat")

  @@map("certificate_templates")
}

// ─── Commerce enums ───────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MPESA
  AIRTEL_MONEY
  TIGO_PESA
  HALOPESA
  CARD
  BANK_TRANSFER
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id             String         @id @default(cuid())
  userId         String @map("userid")
  user           User           @relation("UserOrders", fields: [userId], references: [id])
  status         OrderStatus    @default(PENDING)
  subtotal       Decimal        @db.Decimal(10, 2)
  discountAmount Decimal        @db.Decimal(10, 2) @default(0) @map("discountamount")
  total          Decimal        @db.Decimal(10, 2)
  couponCode     String?        @db.VarChar(50) @map("couponcode")
  paymentMethod  PaymentMethod?
  paymentRef     String?        @db.VarChar(191) @map("paymentref")
  items          OrderItem[]
  createdAt      DateTime       @default(now()) @map("createdat")
  updatedAt      DateTime       @updatedAt @map("updatedat")

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String @map("orderid")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courseId  String? @map("courseid")
  course    Course?  @relation("OrderItems", fields: [courseId], references: [id])
  kitId     String? @map("kitid")
  kit       Kit?     @relation("KitOrderItems", fields: [kitId], references: [id])
  programId String? @map("programid")
  program   Program? @relation(fields: [programId], references: [id])
  price     Decimal  @db.Decimal(10, 2)

  @@map("order_items")
}

model KitPurchase {
  id          String   @id @default(cuid())
  userId      String @map("userid")
  user        User     @relation("UserKitPurchases", fields: [userId], references: [id], onDelete: Cascade)
  kitId       String @map("kitid")
  kit         Kit      @relation("KitPurchases", fields: [kitId], references: [id], onDelete: Cascade)
  orderId     String? @map("orderid")
  purchasedAt DateTime @default(now()) @map("purchasedat")

  @@unique([userId, kitId])
  @@map("kit_purchases")
}

// ─── Password reset ───────────────────────────────────────────────────────────
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String @map("userid")
  token     String    @unique @db.VarChar(191)
  expiresAt DateTime @map("expiresat")
  usedAt    DateTime? @map("usedat")
  createdAt DateTime  @default(now()) @map("createdat")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Community & Discussions ──────────────────────────────────────────────────

model Discussion {
  id           String            @id @default(cuid())
  authorId     String @map("authorid")
  author       User              @relation("UserDiscussions", fields: [authorId], references: [id])
  courseId     String? @map("courseid")
  course       Course?           @relation("CourseDiscussions", fields: [courseId], references: [id])
  channel      String            @default("general") @db.VarChar(100)
  title         String           @db.VarChar(255)
  body          String           @db.Text
  excerpt       String?          @db.Text
  coverImageUrl String? @map("coverimageurl")
  isPinned      Boolean          @default(false) @map("ispinned")
  isResolved   Boolean           @default(false) @map("isresolved")
  replies      DiscussionReply[]
  likes        DiscussionLike[]
  createdAt    DateTime          @default(now()) @map("createdat")
  updatedAt    DateTime          @updatedAt @map("updatedat")

  @@index([channel])
  @@index([courseId])
  @@map("discussions")
}

model DiscussionReply {
  id           String         @id @default(cuid())
  discussionId String @map("discussionid")
  discussion   Discussion     @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  authorId     String @map("authorid")
  author       User           @relation("UserReplies", fields: [authorId], references: [id])
  body         String         @db.Text
  isAccepted   Boolean        @default(false) @map("isaccepted")
  likes        DiscussionLike[]
  createdAt    DateTime       @default(now()) @map("createdat")
  updatedAt    DateTime       @updatedAt @map("updatedat")

  @@map("discussion_replies")
}

model DiscussionLike {
  id           String           @id @default(cuid())
  userId       String @map("userid")
  user         User             @relation("UserLikes", fields: [userId], references: [id])
  discussionId String? @map("discussionid")
  discussion   Discussion?      @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  replyId      String? @map("replyid")
  reply        DiscussionReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now()) @map("createdat")

  @@unique([userId, discussionId])
  @@unique([userId, replyId])
  @@map("discussion_likes")
}

// ─── Notifications ────────────────────────────────────────────────────────────

enum NotificationType {
  REPLY_ON_POST
  LIKE_ON_POST
  NEW_ENROLLMENT
  COURSE_COMPLETE
  CERTIFICATE_ISSUED
  ASSIGNMENT_SUBMITTED
  ASSIGNMENT_GRADED
  ASSIGNMENT_REVISION_REQUESTED
  MENTOR_REQUEST
  MENTOR_REQUEST_UPDATE
  MENTOR_SESSION_SCHEDULED
  MENTOR_SESSION_REMINDER
  PROGRAM_REGISTERED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String @map("userid")
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  href      String?          @db.VarChar(500)
  isRead    Boolean          @default(false) @map("isread")
  createdAt DateTime         @default(now()) @map("createdat")

  @@index([userId, isRead])
  @@map("notifications")
}

model NotificationPreference {
  id           String  @id @default(cuid())
  userId       String @map("userid")
  user         User    @relation("UserNotificationPrefs", fields: [userId], references: [id], onDelete: Cascade)
  category     String  @db.VarChar(100)
  emailEnabled Boolean @default(true) @map("emailenabled")
  inAppEnabled Boolean @default(true) @map("inappenabled")
  pushEnabled  Boolean @default(false) @map("pushenabled")

  @@unique([userId, category])
  @@map("notification_preferences")
}

// ─── Assignments ──────────────────────────────────────────────────────────────

enum AssignmentSubmissionStatus {
  DRAFT
  SUBMITTED
  REVISION_REQUESTED
  GRADED
}

model Assignment {
  id           String   @id @default(cuid())
  lessonId     String   @unique @map("lessonid")
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  instructions String?  @db.Text
  rubric       Json?
  maxScore     Int      @default(100) @map("maxscore")
  dueAt        DateTime? @map("dueat")
  submissions  AssignmentSubmission[]
  createdAt    DateTime @default(now()) @map("createdat")
  updatedAt    DateTime @updatedAt @map("updatedat")

  @@map("assignments")
}

model AssignmentSubmission {
  id             String                     @id @default(cuid())
  assignmentId   String @map("assignmentid")
  assignment     Assignment                 @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  enrollmentId   String @map("enrollmentid")
  enrollment     Enrollment                 @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  userId         String @map("userid")
  user           User                       @relation("StudentSubmissions", fields: [userId], references: [id])
  status         AssignmentSubmissionStatus @default(DRAFT)
  textResponse   String?                    @db.Text @map("textresponse")
  githubUrl      String?                    @db.VarChar(500) @map("githuburl")
  score          Int?
  feedback       String?                    @db.Text
  submittedAt    DateTime? @map("submittedat")
  gradedAt       DateTime? @map("gradedat")
  gradedById     String? @map("gradedbyid")
  gradedBy       User?                      @relation("GradedSubmissions", fields: [gradedById], references: [id])
  files          AssignmentSubmissionFile[]
  createdAt      DateTime                   @default(now()) @map("createdat")
  updatedAt      DateTime                   @updatedAt @map("updatedat")

  @@unique([assignmentId, enrollmentId])
  @@map("assignment_submissions")
}

model AssignmentSubmissionFile {
  id           String               @id @default(cuid())
  submissionId String @map("submissionid")
  submission   AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fileName     String               @db.VarChar(255) @map("filename")
  filePath     String               @db.VarChar(500) @map("filepath")
  mimeType     String?              @db.VarChar(100) @map("mimetype")
  sizeBytes    Int? @map("sizebytes")

  @@map("assignment_submission_files")
}

// ─── Instructor payouts ───────────────────────────────────────────────────────

enum PayoutMethod {
  MPESA
  BANK_TRANSFER
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

model InstructorPayoutProfile {
  id                String        @id @default(cuid())
  userId            String        @unique @map("userid")
  user              User          @relation("InstructorPayoutProfile", fields: [userId], references: [id], onDelete: Cascade)
  preferredMethod   PayoutMethod  @default(MPESA)
  mpesaPhone        String?       @db.VarChar(20) @map("mpesaphone")
  bankName          String?       @db.VarChar(100) @map("bankname")
  bankAccountName   String?       @db.VarChar(100) @map("bankaccountname")
  bankAccountNumber String?       @db.VarChar(50) @map("bankaccountnumber")
  bankSwift         String?       @db.VarChar(20) @map("bankswift")
  updatedAt         DateTime      @updatedAt @map("updatedat")

  @@map("instructor_payout_profiles")
}

model InstructorPayout {
  id           String       @id @default(cuid())
  instructorId String @map("instructorid")
  instructor   User         @relation("InstructorPayouts", fields: [instructorId], references: [id])
  amount       Decimal      @db.Decimal(10, 2)
  method       PayoutMethod
  status       PayoutStatus @default(PENDING)
  note         String?      @db.Text
  processedAt  DateTime? @map("processedat")
  createdAt    DateTime     @default(now()) @map("createdat")
  updatedAt    DateTime     @updatedAt @map("updatedat")

  @@index([instructorId])
  @@map("instructor_payouts")
}

// ─── Learning kits ────────────────────────────────────────────────────────────

enum KitStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum KitDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum KitMaterialType {
  GUIDE
  VIDEO
  PDF
  WORKSHEET
  PROJECT
}

model Kit {
  id                 String        @id @default(cuid())
  slug               String        @unique @db.VarChar(191)
  title              String
  subtitle           String?
  description        String?       @db.Text
  thumbnailUrl       String? @map("thumbnailurl")
  category           String?       @db.VarChar(100)
  difficulty         KitDifficulty @default(BEGINNER)
  ageRange           String?       @db.VarChar(50) @map("agerange")
  price              Decimal?      @db.Decimal(10, 2)
  isFree             Boolean       @default(false) @map("isfree")
  status             KitStatus     @default(DRAFT)
  learningOutcomes   Json? @map("learningoutcomes")
  projectIdeas       Json? @map("projectideas")
  relatedCourseSlugs Json? @map("relatedcourseslugs")
  inventoryCount     Int           @default(0) @map("inventorycount")
  components         KitComponent[]
  materials          KitMaterial[]
  gallery            KitGalleryImage[]
  orderItems         OrderItem[]   @relation("KitOrderItems")
  purchases          KitPurchase[] @relation("KitPurchases")
  orgInventory       OrgKitInventory[]
  orgRequests        OrgKitRequest[]
  createdAt          DateTime      @default(now()) @map("createdat")
  updatedAt          DateTime      @updatedAt @map("updatedat")

  @@map("kits")
}

model KitComponent {
  id          String  @id @default(cuid())
