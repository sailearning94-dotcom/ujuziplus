# Database (Railway MySQL)
DATABASE_URL="mysql://root:password@mysql.railway.internal:3306/railway"

# Auth (required)
NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="https://ujuzipluse.co.tz"

# ClickPesa Payment Gateway (https://merchant.clickpesa.com → Settings → Developers)
# Create an application, generate an API key (shown once — copy immediately!)
CLICKPESA_CLIENT_ID=
CLICKPESA_API_KEY=

# Webhook secret — set this in the ClickPesa dashboard under webhook settings
# Used to verify the HMAC-SHA256 checksum on incoming webhook payloads
CLICKPESA_WEBHOOK_SECRET=

# Email (optional — logs to console when unset)
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_INBOX=hello@ujuzipluse.co.tz

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:hello@ujuzipluse.co.tz"
