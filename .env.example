# Database
DATABASE_URL="mysql://user:password@localhost:3306/ujuzilab"

# Auth (required)
NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ClickPesa Payment Gateway (https://merchant.clickpesa.com → Settings → Developers)
# Create an application, generate an API key (shown once — copy immediately!)
CLICKPESA_CLIENT_ID=
CLICKPESA_API_KEY=

# Webhook secret — set this in the ClickPesa dashboard under webhook settings
# Used to verify the HMAC-SHA256 checksum on incoming webhook payloads
CLICKPESA_WEBHOOK_SECRET=

# Email (optional — logs to console when unset)
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_INBOX=hello@ujuzilab.com
